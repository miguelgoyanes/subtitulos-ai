{
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devPath": "http://localhost:1420",
    "distDir": "../dist",
    "withGlobalTauri": false
  },
  "package": { "productName": "Subtitulos", "version": "2.0.5" },
  "tauri": {
    "allowlist": {
      "all": false,
      "dialog": { "all": true, "open": true, "save": true },
      "fs": { "all": true, "readFile": true, "writeFile": true, "scope": ["**"] },
      "path": { "all": true },
      "shell": { "all": true, "open": true, "scope": [{ "name": "python", "cmd": "python", "args": true }] }
    },
    "bundle": {
      "active": true, "targets": "all", "identifier": "com.subtitulos.app",
      "icon": ["icons/32x32.png", "icons/128x128.png", "icons/128x128@2x.png", "icons/icon.icns", "icons/icon.ico"],
      "resources": ["scripts/*"]
    },
    "security": { "csp": null },
    "windows": [{ "title": "Subtítulos Automáticos 2.0", "width": 1200, "height": 800, "minWidth": 900, "minHeight": 600, "resizable": true }]
  }
}
